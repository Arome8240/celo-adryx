DATABASE_URL="postgresql://user:password@host:5432/dbname"

JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

CORS_ORIGINS="http://localhost:3000"

# SIWE — must match what the frontend sends as the `domain`/`uri` in the message.
SIWE_DOMAIN="localhost:3000"
SIWE_URI="http://localhost:3000"

AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# "test" or "production" — always explicit, never left to default.
AMADEUS_ENV=test

# Celo mainnet.
CELO_RPC_URL=https://forno.celo.org
CHAIN_ID=42220
# On mainnet this is still the cUSD contract (Mento's newer docs call it
# "StableTokenUSD") — there's no separate mainnet "USDm" token. Celo Sepolia
# testnet has a genuinely different USDm (Mento Dollar) contract instead.
USDM_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# No real values here — fill in once FlightEscrow is actually deployed and you
# have a funded operator wallet + treasury address. Never a placeholder.
ESCROW_CONTRACT_ADDRESS=
OPERATOR_PRIVATE_KEY=
TREASURY_ADDRESS=
OPS_SECRET=
